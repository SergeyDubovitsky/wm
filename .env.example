# Shared MVP configuration for local applications and demo infrastructure.

# Optional image overrides for local development.
MOSQUITTO_IMAGE=eclipse-mosquitto:2
KAFKA_IMAGE=apache/kafka:4.2.0
REDPANDA_CONNECT_IMAGE=docker.redpanda.com/redpandadata/connect
KAFKA_UI_IMAGE=provectuslabs/kafka-ui
MQTTX_WEB_IMAGE=emqx/mqttx-web
CLICKHOUSE_IMAGE=clickhouse/clickhouse-server:25.4
POSTGRES_IMAGE=postgres:17
KAFKA_CONNECT_BASE_IMAGE=confluentinc/cp-kafka-connect:7.7.1
CLICKHOUSE_KAFKA_CONNECT_VERSION=latest
GRAFANA_BASE_IMAGE=grafana/grafana:12.2.0
GRAFANA_IMAGE=web-monitoring/grafana-clickhouse:local
GRAFANA_CLICKHOUSE_DATASOURCE_VERSION=4.15.0

# Published host ports.
MQTT_PORT=1883
MQTT_WS_PORT=9001
KAFKA_PORT=19092
REDPANDA_CONNECT_PORT=4195
KAFKA_CONNECT_REST_PORT=8083
KAFKA_CONNECT_JMX_PORT=9102
KAFKA_UI_PORT=8080
MQTTX_WEB_PORT=8081
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
GRAFANA_PORT=3000
POSTGRES_PORT=5432

# Broker URI used by local applications.
MQTT_BROKER=mqtt://localhost:1883
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
CLICKHOUSE_HOST=localhost
CLICKHOUSE_DATABASE=wm
CLICKHOUSE_USER=wm
CLICKHOUSE_PASSWORD=change-me-local-clickhouse
CLICKHOUSE_SECURE=false
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-local-grafana
POSTGRES_HOST=localhost
POSTGRES_DB=wm_config_registry
POSTGRES_USER=wm
POSTGRES_PASSWORD=change-me-local-postgres
CONFIG_REGISTRY_DATABASE_URL=postgresql+asyncpg://wm:change-me-local-postgres@localhost:5432/wm_config_registry
CONFIG_REGISTRY_KAFKA_CLIENT_ID=config-registry
CONFIG_REGISTRY_OUTBOX_BATCH_LIMIT=100
CONFIG_REGISTRY_OUTBOX_LEASE_SECONDS=30
CONFIG_REGISTRY_OUTBOX_RETRY_DELAY_SECONDS=30
CONFIG_REGISTRY_OUTBOX_MAX_ATTEMPTS=5

# Local Kafka Connect internal topics. These are created by kafka-init so the
# future Kafka Connect service does not depend on broker auto-create.
KAFKA_CONNECT_CONFIG_TOPIC=wm.local.kafka-connect.configs
KAFKA_CONNECT_OFFSET_TOPIC=wm.local.kafka-connect.offsets
KAFKA_CONNECT_STATUS_TOPIC=wm.local.kafka-connect.status
KAFKA_CONNECT_GROUP_ID=wm-local-clickhouse-connect
KAFKA_CONNECTOR_NAME=wm-clickhouse-telemetry-store-v1

# Local MQTT credentials for broker access and host-side apps.
MQTT_USERNAME=admin
MQTT_PASSWORD=change-me-local-mqtt

# Demo KNX endpoints. Replace with real values only in your local .env.
KNX_LOCAL_GATEWAY_IP=0.0.0.0
KNX_LOCAL_GATEWAY_PORT=3671
KNX_LOCAL_ROUTE_BACK=false

KNX_EXTERNAL_GATEWAY_IP=0.0.0.0
KNX_EXTERNAL_GATEWAY_PORT=7171
KNX_EXTERNAL_ROUTE_BACK=true
