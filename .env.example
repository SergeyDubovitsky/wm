# Shared MVP configuration for local applications and demo infrastructure.

# Optional image overrides for local development.
MOSQUITTO_IMAGE=eclipse-mosquitto:2
KAFKA_IMAGE=apache/kafka:4.2.0
REDPANDA_CONNECT_IMAGE=docker.redpanda.com/redpandadata/connect
KAFKA_UI_IMAGE=provectuslabs/kafka-ui
MQTTX_WEB_IMAGE=emqx/mqttx-web

# Published host ports.
MQTT_PORT=1883
MQTT_WS_PORT=9001
KAFKA_PORT=19092
REDPANDA_CONNECT_PORT=4195
KAFKA_UI_PORT=8080
MQTTX_WEB_PORT=8081

# Broker URI used by local applications.
MQTT_BROKER=mqtt://localhost:1883
KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# Local MQTT credentials for broker access and host-side apps.
MQTT_USERNAME=admin
MQTT_PASSWORD=change-me-local-mqtt

# Demo KNX endpoints. Replace with real values only in your local .env.
KNX_LOCAL_GATEWAY_IP=0.0.0.0
KNX_LOCAL_GATEWAY_PORT=3671
KNX_LOCAL_ROUTE_BACK=false

KNX_EXTERNAL_GATEWAY_IP=0.0.0.0
KNX_EXTERNAL_GATEWAY_PORT=7171
KNX_EXTERNAL_ROUTE_BACK=true
