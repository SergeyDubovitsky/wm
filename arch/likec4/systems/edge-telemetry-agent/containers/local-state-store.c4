model {
    extend edge-telemetry-agent {
        local-state-store = container 'Local State Store' {
            description 'Локальное техническое SQLite-хранилище edge-агента: Point State Cache для warm restart и фильтрации изменений, Delivery Outbox для надежной доставки, attempts/status и recovery. Контракты: edge.sqlite-point-state-cache.v1, edge.sqlite-outbox-record.v1.'
            technology 'SQLite'
            style {
                shape storage
            }
        }
    }
}
