views 'Developed Systems / Edge Telemetry Agent' {
    view c2-edge-telemetry-agent-containers of edge-telemetry-agent {
        title 'C2 Containers'
        description 'Контейнерная декомпозиция Edge Telemetry Agent. Каждый контейнер описан в отдельном файле внутри systems/edge-telemetry-agent/containers.'

        include *
        include service-engineer
        include field-protocol-gateways
        include field-protocol-gateways.*
        include monitoring-alarm-platform
        exclude service-engineer -> monitoring-alarm-platform
        exclude service-engineer -> monitoring-alarm-platform.*

        style edge-telemetry-agent {
            color primary
        }

        rank source {
            service-engineer, field-protocol-gateways
        }

        rank sink {
            monitoring-alarm-platform
        }
    }
}
