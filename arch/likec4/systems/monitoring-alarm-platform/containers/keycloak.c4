model {
    extend monitoring-alarm-platform {
        keycloak = container 'Keycloak' {
            description 'Сервис identity and access management: realms, пользователи, роли, клиенты и выпуск токенов для Platform Frontend и Platform API.'
            technology 'Keycloak / OIDC / OAuth 2.0'
        }
    }
}
