model {
    extend monitoring-alarm-platform {
        mqtt-ingestion-gateway = container 'MQTT Ingestion Gateway' {
            description 'Принимает MQTT telemetry events и service topics от edge-агентов, восстанавливает routing context из topic и предоставляет MQTT-поток для чтения Redpanda.'
            technology 'MQTT broker / ingestion service'
            icon bootstrap:broadcast
        }
    }

}
