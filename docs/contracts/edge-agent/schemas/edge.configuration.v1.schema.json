{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://industrial-edge-web-monitoring.local/contracts/edge-agent/edge.configuration.v1.schema.json",
    "title": "edge.configuration.v1",
    "description": "Runtime-конфигурация Edge Telemetry Agent после сборки agent/sources/points документов.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "agent",
        "delivery",
        "storage",
        "observability",
        "sources",
        "points"
    ],
    "properties": {
        "agent": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "object_id",
                "name",
                "id_file"
            ],
            "properties": {
                "object_id": {
                    "type": "string",
                    "pattern": "^[a-z0-9][a-z0-9_-]{0,127}$"
                },
                "name": {
                    "type": "string",
                    "minLength": 1
                },
                "id_file": {
                    "type": "string",
                    "minLength": 1
                }
            }
        },
        "delivery": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "transport",
                "mqtt"
            ],
            "properties": {
                "transport": {
                    "type": "string",
                    "enum": [
                        "mqtt"
                    ]
                },
                "mqtt": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                        "enabled",
                        "version",
                        "broker",
                        "topic_root",
                        "client_id_prefix",
                        "qos",
                        "clean_start",
                        "session_expiry_seconds",
                        "telemetry_message_expiry_seconds",
                        "publish_metadata",
                        "retain_metadata",
                        "publish_connection_status",
                        "retain_connection_status",
                        "connect_timeout_seconds",
                        "retry_backoff_seconds"
                    ],
                    "properties": {
                        "enabled": {
                            "type": "boolean"
                        },
                        "version": {
                            "type": "string",
                            "const": "5.0"
                        },
                        "broker": {
                            "type": "string",
                            "minLength": 1
                        },
                        "topic_root": {
                            "type": "string",
                            "pattern": "^[a-z0-9][a-z0-9_-]{0,127}(?:/[a-z0-9][a-z0-9_-]{0,127})*$"
                        },
                        "client_id_prefix": {
                            "type": "string",
                            "minLength": 1
                        },
                        "username_env": {
                            "type": [
                                "string",
                                "null"
                            ]
                        },
                        "password_env": {
                            "type": [
                                "string",
                                "null"
                            ]
                        },
                        "qos": {
                            "type": "integer",
                            "enum": [
                                1
                            ]
                        },
                        "clean_start": {
                            "type": "boolean"
                        },
                        "session_expiry_seconds": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "telemetry_message_expiry_seconds": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "publish_metadata": {
                            "type": "boolean"
                        },
                        "retain_metadata": {
                            "type": "boolean"
                        },
                        "publish_connection_status": {
                            "type": "boolean"
                        },
                        "retain_connection_status": {
                            "type": "boolean"
                        },
                        "connect_timeout_seconds": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "retry_backoff_seconds": {
                            "type": "array",
                            "minItems": 1,
                            "items": {
                                "type": "integer",
                                "minimum": 0
                            }
                        }
                    }
                }
            }
        },
        "storage": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "sqlite_path",
                "retention_days",
                "dead_letter_after_attempts"
            ],
            "properties": {
                "sqlite_path": {
                    "type": "string",
                    "minLength": 1
                },
                "retention_days": {
                    "type": "integer",
                    "minimum": 1
                },
                "dead_letter_after_attempts": {
                    "type": "integer",
                    "minimum": 1
                }
            }
        },
        "observability": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "log_level",
                "emit_health_events"
            ],
            "properties": {
                "log_level": {
                    "type": "string",
                    "minLength": 1
                },
                "emit_health_events": {
                    "type": "boolean"
                },
                "metrics_bind": {
                    "type": [
                        "string",
                        "null"
                    ]
                }
            }
        },
        "sources": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": true,
                "required": [
                    "source_id",
                    "type",
                    "enabled",
                    "connection",
                    "acquisition_defaults",
                    "publish_defaults"
                ],
                "properties": {
                    "source_id": {
                        "type": "string",
                        "pattern": "^[a-z0-9][a-z0-9_-]{0,127}$"
                    },
                    "type": {
                        "type": "string",
                        "minLength": 1
                    },
                    "enabled": {
                        "type": "boolean"
                    },
                    "connection": {
                        "type": "object"
                    },
                    "acquisition_defaults": {
                        "$ref": "#/$defs/acquisition_settings"
                    },
                    "publish_defaults": {
                        "$ref": "#/$defs/publish_settings"
                    }
                }
            }
        },
        "points": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "source_id",
                    "point_ref",
                    "name",
                    "value_type",
                    "value_model",
                    "signal_type"
                ],
                "properties": {
                    "source_id": {
                        "type": "string",
                        "pattern": "^[a-z0-9][a-z0-9_-]{0,127}$"
                    },
                    "point_ref": {
                        "type": "string",
                        "minLength": 1
                    },
                    "name": {
                        "type": "string",
                        "minLength": 1
                    },
                    "description": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "value_type": {
                        "type": "string",
                        "enum": [
                            "boolean",
                            "number",
                            "string"
                        ]
                    },
                    "value_model": {
                        "type": "string",
                        "minLength": 1
                    },
                    "signal_type": {
                        "type": "string",
                        "enum": [
                            "command",
                            "feedback",
                            "status",
                            "sensor"
                        ]
                    },
                    "unit": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "acquisition": {
                        "$ref": "#/$defs/acquisition_settings"
                    },
                    "publish": {
                        "$ref": "#/$defs/publish_settings"
                    },
                    "tags": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "$defs": {
        "acquisition_settings": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "listen",
                "read_on_start",
                "periodic_interval_seconds"
            ],
            "properties": {
                "listen": {
                    "type": "boolean"
                },
                "read_on_start": {
                    "type": "boolean"
                },
                "periodic_interval_seconds": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "exclusiveMinimum": 0
                }
            }
        },
        "publish_settings": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "enabled",
                "change_threshold"
            ],
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "change_threshold": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "exclusiveMinimum": 0
                }
            }
        }
    }
}
