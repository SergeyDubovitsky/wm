{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://industrial-edge-web-monitoring.local/contracts/edge-agent/wm.source.meta.catalog.v1.schema.json",
    "title": "wm.source.meta.catalog.v1",
    "description": "Retained source-level metadata catalog всех точек одного source.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "message_type",
        "object_id",
        "agent_id",
        "source_id",
        "source_type",
        "catalog_revision",
        "ts",
        "points"
    ],
    "properties": {
        "message_type": {
            "const": "wm.source.meta.catalog.v1"
        },
        "object_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]{0,127}$"
        },
        "agent_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]{0,127}$"
        },
        "source_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]{0,127}$"
        },
        "source_type": {
            "type": "string",
            "minLength": 1
        },
        "ts": {
            "type": "string",
            "format": "date-time"
        },
        "catalog_revision": {
            "type": "string",
            "minLength": 1,
            "description": "Версия catalog, меняется при изменении состава или metadata points."
        },
        "points": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "point_key",
                    "point_ref",
                    "name",
                    "signal_type",
                    "value_type",
                    "value_model",
                    "tags"
                ],
                "properties": {
                    "point_key": {
                        "type": "string",
                        "pattern": "^(?:[A-Za-z0-9._~-]|%[0-9A-F]{2})+$"
                    },
                    "point_ref": {
                        "type": "string",
                        "minLength": 1
                    },
                    "name": {
                        "type": "string",
                        "minLength": 1
                    },
                    "description": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "signal_type": {
                        "type": "string",
                        "enum": [
                            "command",
                            "feedback",
                            "status",
                            "sensor"
                        ]
                    },
                    "value_type": {
                        "type": "string",
                        "enum": [
                            "boolean",
                            "number",
                            "string"
                        ]
                    },
                    "value_model": {
                        "type": "string",
                        "minLength": 1
                    },
                    "unit": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "tags": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    }
}
