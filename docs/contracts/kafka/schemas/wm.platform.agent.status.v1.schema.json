{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://industrial-edge-web-monitoring.local/contracts/kafka/wm.platform.agent.status.v1.schema.json",
    "title": "wm.platform.agent.status.v1",
    "description": "Canonical agent LWT/status event.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "message_type",
        "tenant_id",
        "asset_id",
        "agent_id",
        "status",
        "ts",
        "ingested_at"
    ],
    "properties": {
        "message_type": {
            "const": "wm.platform.agent.status.v1"
        },
        "tenant_id": {
            "type": "string",
            "minLength": 1
        },
        "asset_id": {
            "type": "string",
            "minLength": 1
        },
        "agent_id": {
            "type": "string",
            "minLength": 1
        },
        "status": {
            "type": "string",
            "enum": [
                "online",
                "offline"
            ]
        },
        "ts": {
            "type": "string",
            "format": "date-time"
        },
        "ingested_at": {
            "type": "string",
            "format": "date-time"
        }
    }
}
